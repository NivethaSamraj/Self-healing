const PACE = {
    micro: 500,
    short: 1000,
    medium: 1500
};

async function settle(page: Page, ms = PACE.short) {
    await page.waitForTimeout(ms);
}

async function firstVisible(
    page: Page,
    candidates: Locator[],
    timeout = 8000
): Promise<Locator> {

    const deadline = Date.now() + timeout;

    while (Date.now() < deadline) {

        for (const c of candidates) {
            try {

                if (await c.first().isVisible()) {
                    return c.first();
                }

            } catch { }
        }

        await page.waitForTimeout(250);
    }

    return candidates[0].first();
}

async function captureElement(
    page: Page,
    elementName: string,
    locator: Locator,
    primaryLocatorStr: string
) {

    try {

        await locator.waitFor({
            state: 'visible',
            timeout: 8000
        });

        const bundle =
            await buildSmartLocatorBundle(
                locator,
                elementName
            );

        const [
            elementShot,
            fullPageShot,
            outerHTML,
            contextDom
        ] = await Promise.all([
            captureElementScreenshot(locator).catch(() => null),
            captureFullPageScreenshot(page).catch(() => null),
            getElementOuterHTML(locator).catch(() => ''),
            getMinimalFullDOM(page).catch(() => '')
        ]);

        await saveElement({
            elementName,
            pageUrl: page.url(),
            primaryLocator: primaryLocatorStr,
            smartLocators: bundle.smartLocators,
            meta: bundle.meta,
            outerHTML,
            context_dom: contextDom,
            elementScreenshot: elementShot,
            fullPageScreenshot: fullPageShot
        });


        allure.attachment(
            'Smart Locators',
            JSON.stringify(
                bundle.smartLocators,
                null,
                2
            ),
            'application/json'
        );

        allure.attachment(
            'Element Metadata',
            JSON.stringify(
                bundle.meta,
                null,
                2
            ),
            'application/json'
        );

        allure.attachment(
            'Outer HTML',
            outerHTML,
            'text/html'
        );
        if (elementShot) {
            allure.attachment(
                'Element Screenshot',
                Buffer.from(
                    elementShot,
                    'base64'
                ),
                'image/jpeg'
            );
        }

        if (fullPageShot) {
            allure.attachment(
                'Full Page Screenshot',
                Buffer.from(
                    fullPageShot,
                    'base64'
                ),
                'image/jpeg'
            );
        }
        console.log(`captured: ${elementName}`);

    } catch (err: any) {

        console.log(
            `capture failed: ${elementName}`
        );
    }
}

async function resolveFromDB(
    page: Page,
    elementName: string
) {

    const row =
        await getElement(elementName);

    if (!row) return null;

    if (row.primary_locator) {

        const primary =
            buildLocator(
                page,
                row.primary_locator
            );

        if (
            primary &&
            await isValidLocator(primary)
        ) {
            return {
                locator: primary,
                strategy: 'db-primary'
            };
        }
    }


    const smart =
        typeof row.smart_locators === 'string'
            ? JSON.parse(row.smart_locators)
            : row.smart_locators;

    console.log(
        'SMART LOCATORS:',
        JSON.stringify(smart, null, 2)
    );

    const priority = [
        'role',
        'testId',
        'label',
        'placeholder',
        'text',
        'alt',
        'title',
        'css',
        'xpath'
    ];

    for (const key of priority) {

        const locStr = smart?.[key];

        if (!locStr) continue;

        const built =
            buildLocator(page, locStr);

        if (built) {

            const valid =
                await isValidLocator(built);

            console.log(
                `[Smart Locator] ${key} = ${locStr}`
            );

            console.log(
                `[Valid] ${valid}`
            );

            if (valid) {

                console.log(
                    `[Smart Locator Success] ${key}`
                );

                return {
                    locator: built,
                    strategy: key
                };
            }
        }
    }

    return null;

}
import {
  beginFlow,
  logStep,
  endFlow
} from "../src/reporting/flowTracker";



async function step(
    page: Page,
    elementName: string,
    captureCandidates: Locator[],
    primaryLocator: string,
    action: (loc: Locator) => Promise<void>,
    label: string
) {

    beginFlow(
   elementName,
   test.info().title,
   page.url()
);
    await test.step(label, async () => {

        const existing = await getElement(elementName);

        //
        // NEW ELEMENT
        //
        if (!existing) {

            await test.step(
                'Baseline Capture',
                async () => {

                    const el =
                        await firstVisible(
                            page,
                            captureCandidates
                        );

                    await captureElement(
                        page,
                        elementName,
                        el,
                        primaryLocator
                    );

                    await action(el);
                    logStep({
    tier: "db",
    action: "Primary Locator",
    locator: primaryLocator,
    status: "success"
});

endFlow({
    finalTier: "db",
    finalLocator: primaryLocator,
    healed: false,
    writtenBack: false
});

                }
            );

            return;
        }

        //
        // DB / SMART LOCATOR
        //
        await test.step(
            'Locator Resolution',
            async () => {

                const resolved =
                    await resolveFromDB(
                        page,
                        elementName
                    );
if (resolved) {

   const tier =
      resolved.strategy === 'db-primary'
         ? 'db'
         : 'smart';

   logStep({
      tier,
      action: resolved.strategy,
      locator: resolved.locator.toString(),
      status: 'success'
   });

   await resolved.locator.scrollIntoViewIfNeeded();

   await action(resolved.locator);

   endFlow({
      finalTier: tier,
      finalLocator: resolved.locator.toString(),
      healed: false,
      writtenBack: false
   });

   throw { success: true };
}

throw new Error('Locator resolution failed');
        });

    }).catch(async (e) => {

    logStep({
       tier: 'db',
       action: 'Locator Resolution',
       status: 'failed'
    });

    if (e?.success) {
        return;
    }

        //
        // AI HEALING
        //
        await test.step(
            `${elementName} - AI Healing`,
            async () => {

                let healed: any;

                await test.step(
                    'Generate AI Locator',
                    async () => {

                        healed =
                            await findWithFallback(
                                page,
                                elementName,
                                page.locator('body'),
                                'ann-taylor page'
                            );

                        allure.attachment(
                            'Healing Result',
                            JSON.stringify(
                                {
                                    element: elementName,
                                    strategy:
                                        healed.strategy ?? 'AI'
                                },
                                null,
                                2
                            ),
                            'application/json'
                        );
                    }
                );

                await test.step(
                    'Validate AI Locator',
                    async () => {

                        if (
                            !(await isValidLocator(
                                healed.locator
                            ))
                        ) {
                            throw new Error(
                                `Could not heal ${elementName}`
                            );
                        }

                    }
                );

                await test.step(
                    'Execute Healed Action',
                    async () => {

                        await healed.locator.scrollIntoViewIfNeeded();

                        await action(
                            healed.locator
                        );
                        logStep({
   tier: 'ai',
   action: 'AI Healing',
   locator: healed.locator.toString(),
   status: 'success'
});

endFlow({
   finalTier: 'ai',
   finalLocator: healed.locator.toString(),
   healed: true,
   writtenBack: true
});

                    }
                );
            }
        );
    });
}
