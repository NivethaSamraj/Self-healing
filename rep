    --ink:#E8EEF7; --muted:#8DA0BF; --faint:#5C6E8C;
    --db:#2DD4A7; --smart:#F4B740; --ai:#FF6B6B; --unres:#6B7A99;
    --accent:#5B8DEF;
    --mono:'JetBrains Mono','SF Mono',ui-monospace,Menlo,Consolas,monospace;
    --sans:'Inter','Segoe UI',system-ui,-apple-system,sans-serif;
  }
  *{box-sizing:border-box}
  body{margin:0;background:
    radial-gradient(1200px 600px at 85% -10%,#16243f 0%,transparent 55%),
    var(--bg);
    color:var(--ink);font-family:var(--sans);
    -webkit-font-smoothing:antialiased;padding:34px 30px 60px;line-height:1.5}

  .topbar{display:flex;align-items:flex-end;justify-content:space-between;
    flex-wrap:wrap;gap:16px;margin-bottom:30px}
  .brand{display:flex;flex-direction:column;gap:6px}
  .brand .kicker{font-family:var(--mono);font-size:12px;letter-spacing:.32em;
    color:var(--db);text-transform:uppercase}
  .brand h1{margin:0;font-size:30px;font-weight:700;letter-spacing:-.01em}
  .brand .sub{color:var(--muted);font-size:14px}
  .gen{font-family:var(--mono);font-size:12px;color:var(--faint);text-align:right}

  /* Hero score */
  .hero{display:grid;grid-template-columns:280px 1fr;gap:22px;margin-bottom:22px}
  @media(max-width:860px){.hero{grid-template-columns:1fr}}
  .score{background:linear-gradient(160deg,var(--panel),var(--panel-2));
    border:1px solid var(--line);border-radius:18px;padding:26px;
    display:flex;flex-direction:column;justify-content:center;align-items:center;
    position:relative;overflow:hidden}
  .ring{position:relative;width:180px;height:180px}
  .ring svg{transform:rotate(-90deg)}
  .ring .val{position:absolute;inset:0;display:flex;flex-direction:column;
    align-items:center;justify-content:center}
  .ring .num{font-size:46px;font-weight:700;letter-spacing:-.02em}
  .ring .num small{font-size:20px;color:var(--muted)}
  .ring .cap{font-family:var(--mono);font-size:11px;letter-spacing:.18em;
    color:var(--muted);text-transform:uppercase;margin-top:2px}

  .dist{background:linear-gradient(160deg,var(--panel),var(--panel-2));
    border:1px solid var(--line);border-radius:18px;padding:24px 26px;
    display:flex;flex-direction:column;gap:18px}
  .dist h3{margin:0;font-size:13px;font-family:var(--mono);letter-spacing:.16em;
    text-transform:uppercase;color:var(--muted);font-weight:600}
  .bar{display:flex;height:46px;border-radius:11px;overflow:hidden;
    background:#0a0f1c;border:1px solid var(--line)}
  .bar .seg{display:flex;align-items:center;justify-content:center;
    color:#06121b;font-weight:700;font-size:13px;transition:width .6s ease;min-width:2px}
  .bar .seg span{padding:0 4px}
  .legend{list-style:none;margin:0;padding:0;display:flex;flex-wrap:wrap;gap:20px}
  .legend li{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)}
  .legend b{color:var(--ink);font-size:15px;margin-left:2px}
  .dot{width:11px;height:11px;border-radius:3px;display:inline-block}

  /* Stat cards */
  .stats{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-bottom:26px}
  @media(max-width:1100px){.stats{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:560px){.stats{grid-template-columns:repeat(2,1fr)}}
  .stat{background:var(--panel);border:1px solid var(--line);border-radius:14px;
    padding:18px 18px 16px}
  .stat .v{font-size:30px;font-weight:700;letter-spacing:-.02em;line-height:1}
  .stat .l{color:var(--muted);font-size:12.5px;margin-top:8px}
  .stat.accent .v{color:var(--db)}

  /* Timeline */
  .section-h{font-family:var(--mono);font-size:12px;letter-spacing:.2em;
    text-transform:uppercase;color:var(--muted);margin:30px 0 14px}
  .timeline{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:8px}
  .tl-chip{display:flex;align-items:center;gap:9px;background:var(--panel);
    border:1px solid var(--line);border-left:3px solid var(--c);
    border-radius:9px;padding:9px 13px;font-size:13px}
  .tl-tier{font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;
    color:var(--c);text-transform:uppercase;font-weight:600}
  .tl-name{color:var(--ink);font-weight:500}
  .tl-wb{font-size:11px;color:var(--db);font-family:var(--mono)}

  /* Table */
  .panel{background:var(--panel);border:1px solid var(--line);border-radius:16px;
    overflow:hidden}
  table.main-t{width:100%;border-collapse:collapse}
  table.main-t thead th{background:#0c1424;color:var(--muted);text-align:left;
    padding:14px 16px;font-size:11.5px;font-family:var(--mono);letter-spacing:.1em;
    text-transform:uppercase;font-weight:600;border-bottom:1px solid var(--line)}
  table.main-t td{padding:13px 16px;border-bottom:1px solid var(--line);font-size:13.5px;
    vertical-align:middle}
  tr.main{cursor:pointer;transition:background .15s}
  tr.main:hover{background:#0f1a2e}
  td.ix{font-family:var(--mono);color:var(--faint);font-size:12px}
  td.el{font-weight:600}
  td.tc{color:var(--muted);font-size:12.5px}
  td.loc{font-family:var(--mono);font-size:11.5px;color:var(--muted);
    max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  td.exp{color:var(--faint);text-align:center;width:30px;transition:transform .2s}
  tr.main.open td.exp{transform:rotate(180deg);color:var(--accent)}
  .tier{padding:5px 11px;border-radius:20px;font-size:11.5px;font-weight:700;
    font-family:var(--mono);letter-spacing:.04em;white-space:nowrap}
  .yes{color:var(--db);font-weight:600;font-size:12.5px}
  .no{color:var(--faint)}

  tr.detail{display:none}
  tr.detail.show{display:table-row}
  tr.detail td{background:var(--panel-2);padding:0 16px 14px}
  table.steps{width:100%;border-collapse:collapse;margin:6px 0 4px}
  table.steps th{background:transparent;color:var(--faint);text-align:left;
    padding:9px 12px;font-size:10.5px;font-family:var(--mono);letter-spacing:.08em;
    text-transform:uppercase;border-bottom:1px solid var(--line)}
  table.steps td{padding:9px 12px;font-size:12px;border-bottom:1px solid #16223a}
  .mini{font-family:var(--mono);font-size:10px;padding:2px 7px;border-radius:5px;
    text-transform:uppercase;letter-spacing:.05em;font-weight:700}
  .mini.db{background:#2DD4A722;color:var(--db)}
  .mini.smart{background:#F4B74022;color:var(--smart)}
  .mini.ai{background:#FF6B6B22;color:var(--ai)}
  .st-success{color:var(--db)} .st-failed{color:var(--ai)} .st-skipped{color:var(--faint)}
  .empty{color:var(--faint);text-align:center;padding:14px}

  .foot{margin-top:26px;color:var(--faint);font-size:12px;font-family:var(--mono);
    text-align:center;letter-spacing:.04em}
