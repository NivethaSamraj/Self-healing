Step 3 — Create the probe script
Create probe-vision.ts:
typescriptimport OpenAI from 'openai';
import * as fs from 'fs';
import * as dotenv from 'dotenv';
dotenv.config({ path: '../.env' }); // points at your existing .env

const client = new OpenAI({
  apiKey: process.env.AZURE_OPENAI_API_KEY!,
  baseURL: `${process.env.AZURE_OPENAI_ENDPOINT}/openai/deployments/${process.env.AZURE_OPENAI_DEPLOYMENT}`,
  defaultQuery: { 'api-version': '2024-02-15-preview' },
  defaultHeaders: { 'api-key': process.env.AZURE_OPENAI_API_KEY! },
});

async function probe(attachImage: boolean) {
  const text =
    'Reply with ONLY the exact text written inside this image. ' +
    'If you cannot see any image, reply exactly: NO_IMAGE';

  const content: any[] = [{ type: 'text', text }];

  if (attachImage) {
    const b64 = fs.readFileSync('./probe.jpg', { encoding: 'base64' });
    content.push({
      type: 'image_url',
      image_url: { url: `data:image/jpeg;base64,${b64}` },
    });
  }

  const res = await client.chat.completions.create({
    model: process.env.AZURE_OPENAI_DEPLOYMENT!,
    messages: [{ role: 'user', content }],
    temperature: 0,
  });

  console.log(`\n=== attachImage=${attachImage} ===`);
  console.log('answer:', res.choices[0].message.content);
  console.log('usage:', res.usage);
}

(async () => {
  try {
    await probe(false); // expect: NO_IMAGE
    await probe(true);  // expect: PURPLE-9173
  } catch (e: any) {
    console.error('API ERROR:', e.status, e.message);
  }
})();
