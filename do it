/**
 * refreshElement.spec.ts  (Playwright Test only — NO jest, NO sinon)
 *
 * Verifies the stale-primary refresh behavior in the fallback engine.
 *
 * What it proves:
 *   1. DB primary still resolves      -> NO refresh   (comparison #1, by resolution)
 *   2. DB primary broken, smart heals  -> refresh, new primary PRESERVES the old
 *                                         strategy (Option B); primary + smart +
 *                                         meta written together
 *   3. DB primary resolves/agrees      -> NO redundant write (comparison #2 path)
 *
 * The DB layer is stubbed by REPLACING the exported functions on the imported
 * module objects (plain monkeypatching — no test framework spy lib needed).
 * The PAGE logic runs for real against locator-lab.html, because recompute must
 * inspect the live DOM via generateSmartLocators.
 *
 * Restore note: we capture the originals in beforeEach and put them back in
 * afterEach, so stubs never leak between tests.
 */

import { test, expect } from '@playwright/test';
import path from 'path';

import { findWithFallback } from '../src/core/healing/fallbackEngine';
import * as elementRepo from '../src/core/db/elementRepo';
import * as healingRepo from '../src/core/db/healingRepo';

// Absolute file:// URL to the deterministic fixture.
// Adjust the relative path if your fixture lives elsewhere.
const FIXTURE_URL =
  'file://' + path.resolve(__dirname, '../fixtures/locator-lab.html');

// ---- Fixture-specific values -------------------------------------------------
// CHANGE THESE to match your locator-lab.html. The element under test should:
//   - expose a UNIQUE accessible role + name (so a role smart locator exists)
//   - also be findable by getByText with the same visible label
// so that test 2 can heal via 'text' yet recompute a 'role' primary.
const EL_NAME = 'login_btn';
const EL_ROLE = 'button';
const EL_LABEL = 'Login';
const ROLE_PRIMARY =
  `getByRole('${EL_ROLE}', { name: '${EL_LABEL}', exact: true })`;
const TEXT_SMART =
  `getByText('${EL_LABEL}', { exact: true })`;
// -----------------------------------------------------------------------------

// ---- Manual stub plumbing ----------------------------------------------------
// Hold the original implementations so we can restore them.
type AnyFn = (...args: any[]) => any;

let originalGetElement: AnyFn;
let originalSaveHealingLog: AnyFn;
let originalRefresh: AnyFn;

// Records every call to refreshElementLocators so tests can assert on it.
let refreshCalls: any[][] = [];

test.beforeEach(() => {
  refreshCalls = [];

  // Save originals
  originalGetElement = (elementRepo as any).getElement;
  originalSaveHealingLog = (healingRepo as any).saveHealingLog;
  originalRefresh = (elementRepo as any).refreshElementLocators;

  // Stub saveHealingLog -> no-op (avoids needing a live DB)
  (healingRepo as any).saveHealingLog = async () => {};

  // Stub refreshElementLocators -> record args, return a fake row
  (elementRepo as any).refreshElementLocators = async (...args: any[]) => {
    refreshCalls.push(args);
    return { element_name: args[0], primary_locator: args[1] };
  };

  // getElement is stubbed per-test (different rows), set a safe default here
  (elementRepo as any).getElement = async () => null;
});

test.afterEach(() => {
  // Restore originals so nothing leaks between tests / files
  (elementRepo as any).getElement = originalGetElement;
  (healingRepo as any).saveHealingLog = originalSaveHealingLog;
  (elementRepo as any).refreshElementLocators = originalRefresh;
});

// Helper to set what getElement returns for a given test
function stubGetElement(row: any) {
  (elementRepo as any).getElement = async () => row;
}

// =============================================================================
// TEST 1 — DB primary still resolves -> no refresh (comparison #1)
// =============================================================================
test('db primary still works -> no refresh', async ({ page }) => {
  await page.goto(FIXTURE_URL);

  stubGetElement({
    element_name: EL_NAME,
    primary_locator: ROLE_PRIMARY,   // resolves on the fixture
    smart_locators: {},
    meta: {},
  });

  const dummy = page.getByRole(EL_ROLE as any, { name: EL_LABEL, exact: true });
  const res = await findWithFallback(page, EL_NAME, dummy, 'refresh-1');

  expect(res.usedStrategy).toBe('db-primary');
  expect(refreshCalls.length).toBe(0);   // page == db -> no write
});

// =============================================================================
// TEST 2 — broken primary, smart heals -> refresh with strategy preserved
// =============================================================================
test('broken role primary heals via text -> new primary is STILL role + bundle refreshed', async ({ page }) => {
  await page.goto(FIXTURE_URL);

  stubGetElement({
    element_name: EL_NAME,
    // OLD strategy = role, STALE name -> STEP 1 fails to resolve
    primary_locator: `getByRole('${EL_ROLE}', { name: 'OLD_NAME', exact: true })`,
    // lower-priority smart locator that still resolves -> heals via 'text'
    smart_locators: { text: TEXT_SMART },
    meta: {},
  });

  const dummy = page.getByRole(EL_ROLE as any, { name: 'OLD_NAME', exact: true });
  const res = await findWithFallback(page, EL_NAME, dummy, 'refresh-2');

  // healed at the smart 'text' tier
  expect(res.usedStrategy).toBe('text');

  // refreshed exactly once
  expect(refreshCalls.length).toBe(1);

  const [name, newPrimary, smart, meta] = refreshCalls[0];

  expect(name).toBe(EL_NAME);

  // Option B: strategy preserved -> still a getByRole locator (value refreshed),
  // NOT the getByText locator that happened to heal it.
  expect(newPrimary).toContain('getByRole');
  expect(newPrimary).not.toBe(TEXT_SMART);

  // primary + smart_locators + meta written together; matchIndex travels in meta
  expect(smart).toBeTruthy();
  expect(meta).toHaveProperty('matchIndex');
});

// =============================================================================
// TEST 3 — db primary resolves/agrees -> no redundant write
// =============================================================================
test('recompute/stored agree -> no write', async ({ page }) => {
  await page.goto(FIXTURE_URL);

  stubGetElement({
    element_name: EL_NAME,
    primary_locator: ROLE_PRIMARY,          // resolves -> STEP 1 succeeds
    smart_locators: { role: ROLE_PRIMARY },
    meta: {},
  });

  const dummy = page.getByRole(EL_ROLE as any, { name: EL_LABEL, exact: true });
  await findWithFallback(page, EL_NAME, dummy, 'refresh-3');

  expect(refreshCalls.length).toBe(0);
});
