3b — the refresh helper. Add above findWithFallback. This holds comparison #2 (the ===):
typescriptasync function refreshStaleElement(
  healed: Locator,
  elementName: string,
  dbPrimary: string | null
): Promise<void> {
  try {
    const b = await recomputeBundleFromElement(healed, dbPrimary);

    if (!b) {
      HealingLogger.warn('No primary recomputed from healed element');
      return;
    }

    // ===== COMPARISON #2: recomputed page primary vs stored db primary =====
    if (b.primary === dbPrimary) {
      HealingLogger.info('Primary', 'Recomputed equals DB; no write');
      return;                      // same -> leave it
    }

    // different -> update primary + smart_locators + meta together
    await refreshElementLocators(
      elementName, b.primary, b.smartLocators, b.meta
    );
    HealingLogger.success(`DB refreshed -> primary: ${b.primary}`);

  } catch (e: any) {
    // refresh must NEVER break the heal itself
    HealingLogger.warn(`Refresh skipped: ${e?.message || 'unknown'}`);
  }
}
