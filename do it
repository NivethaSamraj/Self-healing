typescriptconst PRIMARY_PRIORITY = [
  'role', 'testId', 'label', 'placeholder',
  'text', 'alt', 'title', 'css', 'xpath',
] as const;

/** Highest-priority locator available in a bundle. */
export function pickBestPrimary(
  s: Record<string, string | undefined>
): string | undefined {
  for (const k of PRIMARY_PRIORITY) if (s?.[k]) return s[k];
  return undefined;
}

/** Which getBy* strategy an existing primary string uses. */
function detectStrategy(primary: string): string | null {
  if (primary.startsWith('getByRole')) return 'role';
  if (primary.startsWith('getByTestId')) return 'testId';
  if (primary.startsWith('getByLabel')) return 'label';
  if (primary.startsWith('getByPlaceholder')) return 'placeholder';
  if (primary.startsWith('getByText')) return 'text';
  if (primary.startsWith('getByAltText')) return 'alt';
  if (primary.startsWith('getByTitle')) return 'title';
  return null; // css / xpath / raw
}

/**
 * Preserve the OLD primary's strategy with a refreshed value.
 * Falls back to best-available only if that strategy no longer
 * exists / isn't unique on the current page.
 */
export function pickMatchingPrimary(
  s: Record<string, string | undefined>,
  oldPrimary: string | null
): string | undefined {
  if (oldPrimary) {
    const strat = detectStrategy(oldPrimary);
    if (strat && s[strat]) return s[strat];
  }
  return pickBestPrimary(s);
}

/**
 * ONE extractElementMeta call on a working (healed) locator ->
 * a consistent {primary, smartLocators, meta}. meta carries
 * matchIndex and MUST be stored alongside smartLocators.
 */
export async function recomputeBundleFromElement(
  locator: Locator,
  oldPrimary: string | null
): Promise<{ primary: string; smartLocators: any; meta: any } | null> {
  const meta = await extractElementMeta(locator);
  const smartLocators = await generateSmartLocators(locator.page(), meta);
  const primary = pickMatchingPrimary(smartLocators, oldPrimary);
  if (!primary) return null;
  return { primary, smartLocators, meta };
}
