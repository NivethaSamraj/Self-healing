      font-size='26' font-weight='700' text-anchor='middle' dominant-baseline='middle'>${label}</text>
  </svg>`;
  return 'data:image/svg+xml;utf8,' + encodeURIComponent(svg);
}

const SIZES = ['XS','S','M','L','XL'];

const PRODUCTS = [
  { id:1, name:'Merino Crew Tee',      category:'Tees & Knits', price:48,  rating:4.8, newness:3, img:svgThumb('Merino Crew Tee','#3b6ea5','#15314f'), soldOut:['XS'] },
  { id:2, name:'Ribbed Knit Top',      category:'Tees & Knits', price:62,  rating:4.5, newness:5, img:svgThumb('Ribbed Knit Top','#a55b3b','#4f2415'), soldOut:[] },
  { id:3, name:'Linen Henley',         category:'Tees & Knits', price:54,  rating:4.9, newness:1, img:svgThumb('Linen Henley','#5b8c5a','#244f2b'), soldOut:['XL'] },
  { id:4, name:'Boxy Pocket Tee',      category:'Tees & Knits', price:39,  rating:4.2, newness:2, img:svgThumb('Boxy Pocket Tee','#8c5a8c','#3a153a'), soldOut:[] },
  { id:5, name:'Wrap Midi Dress',      category:'Dresses',      price:128, rating:4.7, newness:4, img:svgThumb('Wrap Midi Dress','#a53b5b','#4f1530'), soldOut:[] },
  { id:6, name:'Tiered Maxi Dress',    category:'Dresses',      price:148, rating:4.4, newness:6, img:svgThumb('Tiered Maxi Dress','#3b8ca5','#15414f'), soldOut:['S'] },
  { id:7, name:'Quilted Field Jacket', category:'Outerwear',    price:198, rating:4.6, newness:2, img:svgThumb('Field Jacket','#7a6f3b','#3a3415'), soldOut:[] },
  { id:8, name:'Wool Topcoat',         category:'Outerwear',    price:268, rating:4.9, newness:1, img:svgThumb('Wool Topcoat','#5a5a6e','#24243a'), soldOut:[] },
  { id:9, name:'High-Rise Straight Jean', category:'Denim',     price:98,  rating:4.3, newness:3, img:svgThumb('Straight Jean','#3b5aa5','#15244f'), soldOut:[] },
  { id:10, name:'Canvas Low Sneaker',  category:'Sneakers',     price:78,  rating:4.1, newness:4, img:svgThumb('Low Sneaker','#5aa58c','#154f3a'), soldOut:[] },
  { id:11, name:'Chelsea Boot',        category:'Boots',        price:158, rating:4.8, newness:2, img:svgThumb('Chelsea Boot','#6e4f3b','#3a2415'), soldOut:[] },
  { id:12, name:'Cashmere Beanie',     category:'Tees & Knits', price:45,  rating:4.0, newness:5, img:svgThumb('Cashmere Beanie','#a5933b','#4f4115'), soldOut:[] },
];

/* ============================================================
   State
   ============================================================ */
let cart = [];
let currentCategory = null;        // null = featured (all)
let currentSort = 'featured';
let activeProduct = null;
let selectedSize = null;
let appliedDiscount = 0;

const VALID_PROMOS = { 'SAVE10': 0.10, 'NOVA20': 0.20 };

/* ============================================================
   Rendering
   ============================================================ */
const grid = document.getElementById('product-grid');

function starString(r){
  const full = Math.round(r);
  return '★'.repeat(full) + '☆'.repeat(5-full) + '  ' + r.toFixed(1);
}

function getVisibleProducts(){
  let list = PRODUCTS.slice();
  if (currentCategory) list = list.filter(p => p.category === currentCategory);
  switch(currentSort){
    case 'price-low':  list.sort((a,b)=>a.price-b.price); break;
    case 'price-high': list.sort((a,b)=>b.price-a.price); break;
    case 'newest':     list.sort((a,b)=>a.newness-b.newness); break;
    case 'rating':     list.sort((a,b)=>b.rating-a.rating); break;
    default: break; // featured = original order
  }
  return list;
}

function renderGrid(){
  const list = getVisibleProducts();
  grid.innerHTML = '';
  list.forEach(p=>{
    const card = document.createElement('div');
    card.className = 'card';
    card.dataset.productId = p.id;
    card.dataset.productName = p.name;
    card.innerHTML = `
      <img class="thumb" src="${p.img}" alt="${p.name}" />
      <div class="body">
        <div class="cat">${p.category}</div>
